# Copy this file to ".env" (same folder) and fill in your real values.
# Get these from your Supabase project: Settings -> API
#
# SUPABASE_URL looks like: https://abcdefghijk.supabase.co
# SUPABASE_KEY: Supabase is moving from "anon"/"service_role" key names to
# "publishable"/"secret" — use whichever your dashboard shows. For this
# app (server-side only, no browser code touches Supabase directly), the
# service_role/secret key is the correct one, since it needs full read/write
# access. Never put this key in any file that ships to a browser.

SUPABASE_URL=
SUPABASE_KEY=

# Set to "false" to pull real, live headlines instead of sample data.
# Leave unset or "true" to use sample data.
USE_SAMPLE_DATA=true

# Required: protects the admin page (/admin.html) and every route that
# can change data (approve/reject/reorder/breaking/refresh) behind a
# single shared password. Without this set, the admin page is BLOCKED
# entirely (fails safe) rather than left open with no password.
# Pick any password you like.
ADMIN_PASSWORD=

# Optional: a long random string used to sign session cookies. If you
# don't set this, one is generated automatically each time the server
# starts — fine for personal use, but it means you'll be logged out
# every time the server restarts or redeploys. Set this yourself (any
# long random string) if you'd rather stay logged in across restarts.
SESSION_SECRET=
